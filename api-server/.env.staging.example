# ─── LinkNPark API — STAGING environment ───────────────────────────────────
# Deploy to Render staging service. Set all values as Render environment vars.
# Do NOT commit real secrets — this file is a template showing required keys.

NODE_ENV=production

# Supabase — use your STAGING Supabase project (separate from production)
SUPABASE_URL=https://<STAGING_PROJECT>.supabase.co
SUPABASE_SERVICE_KEY=<STAGING_SERVICE_ROLE_KEY>

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<REPLACE_WITH_STRONG_SECRET>

# Admin API key — used for sticker pre-registration endpoints
ADMIN_KEY=<REPLACE_WITH_STRONG_ADMIN_KEY>

# Resend (email OTP) — can share production key or use a test domain
RESEND_API_KEY=<RESEND_API_KEY>
FROM_EMAIL=LinkNPark Staging <noreply@linknpark.in>

# CORS — add your scanner landing page URL
ALLOWED_ORIGINS=https://staging.scan.linknpark.in,http://localhost:5500

# Redis (optional — enables multi-instance WebSocket chat)
# Get a free instance from https://upstash.com then paste the connection URL
# REDIS_URL=rediss://:<password>@<host>:<port>

# Truecaller OAuth (optional for staging)
# TRUECALLER_CLIENT_ID=<TRUECALLER_CLIENT_ID>

PORT=3001

# Cloudflare R2 photo storage (optional — falls back to Supabase if unset)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=incident-photos
R2_PUBLIC_URL=
