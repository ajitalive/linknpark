# ─── LinkNPark API — PRODUCTION environment ─────────────────────────────────
# Set all values as Render / Railway environment variables.
# NEVER commit this file with real secrets filled in.

NODE_ENV=production

# Supabase — production project
SUPABASE_URL=https://<PROD_PROJECT>.supabase.co
SUPABASE_SERVICE_KEY=<PROD_SERVICE_ROLE_KEY>

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<REPLACE_WITH_STRONG_SECRET>

# Admin API key
ADMIN_KEY=<REPLACE_WITH_STRONG_ADMIN_KEY>

# Resend (email OTP)
RESEND_API_KEY=<RESEND_API_KEY>
FROM_EMAIL=LinkNPark <noreply@linknpark.in>

# CORS — scanner landing page domains
ALLOWED_ORIGINS=https://scan.linknpark.in,https://linknpark.in,https://www.linknpark.in

# Redis — strongly recommended for production multi-instance resilience
# Get a free instance from https://upstash.com
REDIS_URL=rediss://:<password>@<host>:<port>

# Truecaller OAuth
TRUECALLER_CLIENT_ID=<TRUECALLER_CLIENT_ID>

PORT=3001

# Cloudflare R2 photo storage (optional — falls back to Supabase if unset)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=incident-photos
R2_PUBLIC_URL=
