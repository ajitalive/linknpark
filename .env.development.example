# ===========================================
# StickerOS / LinkNPark — LOCAL DEVELOPMENT
# ===========================================
# Copy this to .env.development and fill in your dev Supabase values
# The API server loads this via: node --env-file=../.env.development server.js

# ---- Supabase (Dev Project) ----
# Create a FREE second Supabase project at https://supabase.com/dashboard
# Go to Settings > API to find these values
SUPABASE_URL=https://YOUR-DEV-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...YOUR_DEV_SERVICE_ROLE_KEY

# ---- Auth ----
JWT_SECRET=dev-secret-local-only-change-in-prod

# ---- Email (Resend) ----
# Leave empty for dev mode — OTP codes print to console instead of sending email
RESEND_API_KEY=
FROM_EMAIL=LinkNPark <onboarding@resend.dev>

# ---- Server ----
PORT=3001
